[
    {
        "id": "tools",
        "children": [
            {
                "caption": "Claude Code",
                "children": [
                    {
                        "caption": "Start Session",
                        "command": "claude_code_start"
                    },
                    {
                        "caption": "Query Claude",
                        "command": "claude_code_query"
                    },
                    {
                        "caption": "Query Selection",
                        "command": "claude_code_query_selection"
                    },
                    { "caption": "-" },
                    {
                        "caption": "Toggle Output",
                        "command": "claude_code_toggle"
                    },
                    {
                        "caption": "Clear Output",
                        "command": "claude_code_clear"
                    },
                    {
                        "caption": "Interrupt",
                        "command": "claude_code_interrupt"
                    },
                    { "caption": "-" },
                    {
                        "caption": "Stop Session",
                        "command": "claude_code_stop"
                    },
                    { "caption": "-" },
                    {
                        "caption": "Settings...",
                        "command": "edit_settings",
                        "args": {
                            "base_file": "${packages}/ClaudeCode/ClaudeCode.sublime-settings",
                            "default": "// Claude Code Settings\n// See default settings on the left for available options\n{\n}\n"
                        }
                    }
                ]
            }
        ]
    },
    {
        "id": "preferences",
        "children": [
            {
                "id": "package-settings",
                "children": [
                    {
                        "caption": "ClaudeCode",
                        "mnemonic": "C",
                        "children": [
                            {
                                "caption": "Settings – Default",
                                "command": "open_file",
                                "args": {
                                    "file": "${packages}/ClaudeCode/ClaudeCode.sublime-settings"
                                }
                            },
                            {
                                "caption": "Settings – User",
                                "command": "open_file",
                                "args": {
                                    "file": "${packages}/User/ClaudeCode.sublime-settings"
                                }
                            },
                            { "caption": "-" },
                            {
                                "caption": "Key Bindings – Default",
                                "command": "open_file",
                                "args": {
                                    "file": "${packages}/ClaudeCode/Default.sublime-keymap"
                                }
                            },
                            {
                                "caption": "Key Bindings – User",
                                "command": "open_file",
                                "args": {
                                    "file": "${packages}/User/Default (OSX).sublime-keymap"
                                }
                            }
                        ]
                    }
                ]
            }
        ]
    }
]
